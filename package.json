{
  "name": "esphome-config-ts",
  "version": "0.1.0",
  "description": "",
  "scripts": {
    "prepare": "npm run prepare:tspatch && npm run build:tsc",
    "prepare:tspatch": "ts-patch install",
    "build:generator": "node --loader ts-node/esm ./src/generator/build.ts",
    "build:tsc": "tsc",
    "build": "npm run build:generator && npm run build:tsc",
    "test": "node --loader ts-node/esm ./examples/esp32_buttons.ts",
    "madge": "madge --circular --extensions ts ./src"
  },
  "type": "module",
  "main": "dist/",
  "devDependencies": {
    "@tsconfig/node-lts": "^24.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "madge": "^8.0.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "ts-patch": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-transform-paths": "^3.5.6"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "madge": {
    "detectiveOptions": {
      "es6": {
        "skipTypeImports": true
      },
      "ts": {
        "skipTypeImports": true
      }
    }
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
